@prefix dcai: <urn:dcai:ontology:> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcai:ImpactObservationShape
  a sh:NodeShape ;
  sh:targetClass dcai:ImpactObservation ;
  sh:property [
    sh:path dcai:impactForIncident ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class dcai:InfrastructureIncident
  ] ;
  sh:property [
    sh:path dcai:estimatedCapacityRiskKw ;
    sh:minCount 0 ;
    sh:datatype xsd:decimal
  ] ;
  sh:property [
    sh:path dcai:affectedGpuCount ;
    sh:minCount 0 ;
    sh:datatype xsd:integer
  ] ;
  sh:property [
    sh:path dcai:hasRedundancyStateConcept ;
    sh:minCount 0 ;
    sh:class dcai:RedundancyState
  ] ;
  sh:property [
    sh:path dcai:hasMitigationStateConcept ;
    sh:minCount 0 ;
    sh:class dcai:MitigationState
  ] ;
  sh:property [
    sh:path dcai:hasVendorStateConcept ;
    sh:minCount 0 ;
    sh:class dcai:VendorState
  ] .

dcai:EvidenceSupportShape
  a sh:NodeShape ;
  sh:targetClass dcai:EvidenceRecord ;
  sh:or (
    [ sh:property [ sh:path dcai:supportsFact ; sh:minCount 1 ] ]
    [ sh:property [ sh:path dcai:contradictsFact ; sh:minCount 1 ] ]
  ) ;
  sh:property [
    sh:path dcai:hasConfidenceState ;
    sh:minCount 1 ;
    sh:datatype xsd:string
  ] ;
  sh:property [
    sh:path dcai:hasEvidenceConfidence ;
    sh:minCount 1 ;
    sh:class dcai:EvidenceConfidenceState
  ] ;
  sh:property [
    sh:path dcai:hasEvidenceTimestamp ;
    sh:minCount 1 ;
    sh:datatype xsd:dateTime
  ] .

dcai:TelemetryEvidenceShape
  a sh:NodeShape ;
  sh:targetClass dcai:TelemetryEvidence ;
  sh:property [
    sh:path dcai:hasTelemetryAlertId ;
    sh:minCount 0 ;
    sh:datatype xsd:string
  ] ;
  sh:property [
    sh:path dcai:hasAlertType ;
    sh:minCount 0 ;
    sh:datatype xsd:string
  ] ;
  sh:property [
    sh:path dcai:hasAlertSeverity ;
    sh:minCount 0 ;
    sh:datatype xsd:string
  ] ;
  sh:property [
    sh:path dcai:alertTriggeredAt ;
    sh:minCount 0 ;
    sh:datatype xsd:dateTime
  ] ;
  sh:property [
    sh:path dcai:alertResolvedAt ;
    sh:minCount 0 ;
    sh:datatype xsd:dateTime
  ] ;
  sh:property [
    sh:path dcai:hasTelemetryState ;
    sh:minCount 0 ;
    sh:class dcai:TelemetryStatus
  ] .

dcai:ValidationEvidenceShape
  a sh:NodeShape ;
  sh:targetClass dcai:ValidationEvidence ;
  sh:property [
    sh:path dcai:hasValidationId ;
    sh:minCount 1 ;
    sh:datatype xsd:string
  ] ;
  sh:property [
    sh:path dcai:hasValidationStatus ;
    sh:minCount 1 ;
    sh:datatype xsd:string
  ] ;
  sh:property [
    sh:path dcai:hasValidationState ;
    sh:minCount 1 ;
    sh:class dcai:ValidationStatus
  ] .

dcai:WorkOrderEvidenceShape
  a sh:NodeShape ;
  sh:targetClass dcai:WorkOrderEvidence ;
  sh:property [
    sh:path dcai:hasWorkOrderId ;
    sh:minCount 1 ;
    sh:datatype xsd:string
  ] ;
  sh:property [
    sh:path dcai:hasWorkOrderState ;
    sh:minCount 0 ;
    sh:class dcai:WorkOrderStatus
  ] .
