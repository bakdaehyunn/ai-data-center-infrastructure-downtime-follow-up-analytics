@prefix dcai: <urn:dcai:ontology:> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcai:AIProposedTripleSetShape
  a sh:NodeShape ;
  sh:targetClass dcai:ProposedTripleSet ;
  sh:property [
    sh:path dcai:proposesTriple ;
    sh:minCount 1 ;
    sh:datatype xsd:string
  ] ;
  sh:property [
    sh:path dcai:validatedAgainstShape ;
    sh:minCount 1 ;
    sh:datatype xsd:anyURI
  ] ;
  sh:property [
    sh:path prov:wasGeneratedBy ;
    sh:minCount 1
  ] .
