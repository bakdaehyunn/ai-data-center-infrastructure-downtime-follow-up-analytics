@prefix dcai: <urn:dcai:ontology:> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcai:DependencyEdgeShape
  a sh:NodeShape ;
  sh:targetClass dcai:DependencyEdge ;
  sh:property [
    sh:path dcai:hasDependentAsset ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class dcai:InfrastructureAsset
  ] ;
  sh:property [
    sh:path dcai:hasDependencyAsset ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class dcai:InfrastructureAsset
  ] ;
  sh:property [
    sh:path dcai:hasDependencyRole ;
    sh:minCount 1 ;
    sh:datatype xsd:string
  ] ;
  sh:property [
    sh:path dcai:hasDependencyRoleConcept ;
    sh:minCount 1 ;
    sh:class dcai:DependencyRole
  ] ;
  sh:property [
    sh:path dcai:hasImpactScope ;
    sh:minCount 1 ;
    sh:datatype xsd:string
  ] ;
  sh:property [
    sh:path dcai:hasImpactScopeConcept ;
    sh:minCount 1 ;
    sh:class dcai:ImpactScope
  ] .

dcai:DependencyPathShape
  a sh:NodeShape ;
  sh:targetClass dcai:DependencyPath ;
  sh:property [
    sh:path dcai:hasPathStep ;
    sh:minCount 1 ;
    sh:class dcai:DependencyEdge
  ] .
