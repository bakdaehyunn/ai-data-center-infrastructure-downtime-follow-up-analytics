@prefix dcai: <urn:dcai:ontology:> .
@prefix fixture: <urn:dcai:fixture:invalid:missing-asset-link:> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

fixture:source-system
  rdf:type dcai:SourceSystem .

fixture:import-activity
  rdf:type dcai:ImportActivity .

fixture:source-record-inc-missing-asset
  rdf:type dcai:SourceRecord ;
  dcai:hasSourceRecordId "SRC-INVALID-MISSING-ASSET" ;
  dcai:hasSourceSystem fixture:source-system ;
  prov:wasGeneratedBy fixture:import-activity .

fixture:stage-validation
  rdf:type dcai:WorkflowStage .

fixture:inc-missing-asset
  rdf:type dcai:InfrastructureIncident ;
  dcai:hasIdentifier "INC-MISSING-ASSET" ;
  dcai:hasCurrentStage fixture:stage-validation ;
  prov:wasDerivedFrom fixture:source-record-inc-missing-asset .
