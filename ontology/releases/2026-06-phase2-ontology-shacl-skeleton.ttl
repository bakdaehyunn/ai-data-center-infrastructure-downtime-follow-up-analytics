dcai-release:2026-06-phase2-ontology-shacl-skeleton
  rdf:type owl:Ontology ;
  dcterms:title "Phase 2 ontology and SHACL contract skeleton release" ;
  dcterms:description "Parseable skeleton release for ontology module boundaries, SHACL shape boundaries, fixture expectations, and validation commands. This release does not implement runtime RDF ingestion, SPARQL query behavior, reasoning, Java/Kotlin service code, or UI redesign." ;
  dcterms:created "2026-06-07"^^xsd:date ;
  dcterms:requires dcai-release:2026-06-phase1-scaffold ;
