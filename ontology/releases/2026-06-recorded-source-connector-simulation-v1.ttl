dcai-release:2026-06-recorded-source-connector-simulation-v1
  rdf:type owl:Ontology ;
  dcterms:title "Recorded source-system connector simulation v1 release" ;
  dcterms:description "Internal local recorded source-system export simulation for ontology-native ingestion. This release adds controlled CSV export fixtures for incident/workflow, asset/topology, work-order/validation, and telemetry/impact source families; maps them through connector-style adapters into existing SourceExtract DTOs; reports invalid-row quarantine and duplicate events; promotes accepted rows through existing SHACL/provenance gates; and adds focused deterministic rerun, promotion, and lifecycle inspection tests. It does not add public endpoints, authentication, UI redesign, real external connectors, AI governance, commit, or push." ;
  dcterms:created "2026-06-10"^^xsd:date ;
  dcterms:requires dcai-release:2026-06-file-backed-local-ingestion-inspection-v1 ;
  dcterms:hasPart
