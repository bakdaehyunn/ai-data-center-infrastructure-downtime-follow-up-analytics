dcai-release:2026-06-phase17-query-result-contract-shaping
  rdf:type owl:Ontology ;
  dcterms:title "Phase 17 query result contract shaping release" ;
  dcterms:description "Implementation release that adds stable typed query-result envelopes for future semantic service responses while keeping execution CLI-only. This release does not implement public endpoints, graph writes, SPARQL Update execution, reasoning orchestration, UI redesign, old-runtime removal, commit, or push." ;
  dcterms:created "2026-06-07"^^xsd:date ;
  dcterms:requires dcai-release:2026-06-phase16-controlled-read-only-query-execution ;
  dcterms:hasPart
    <../../semantic-service/src/main/kotlin/com/dcai/semanticservice/query/QueryResultEnvelope.kt>,
    <../../semantic-service/src/main/kotlin/com/dcai/semanticservice/query/QueryResultShaper.kt>,
    <../../semantic-service/src/main/kotlin/com/dcai/semanticservice/runtime/SemanticServiceApplication.kt>,
    <../../docs/ontology-native/phase17_query_result_contract_shaping.md> .
