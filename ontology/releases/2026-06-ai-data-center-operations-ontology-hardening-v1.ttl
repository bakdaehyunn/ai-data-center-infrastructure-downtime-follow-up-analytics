dcai-release:2026-06-ai-data-center-operations-ontology-hardening-v1
  rdf:type owl:Ontology ;
  dcterms:title "AI data center operations ontology hardening v1 release" ;
  dcterms:description "Internal ontology-native hardening release for AI data center downtime follow-up semantics. This release strengthens ontology modules for hall/zone/row/rack/GPU pod topology, UPS/PDU/cooling/telemetry asset concepts, controlled operational state vocabularies, stricter SHACL constraints where promoted data supports them, recovery-blocker reasoning, generated recorded scenario coverage, and competency tests for affected asset, upstream dependencies, evidence state, recovery blocker, blast radius, and source-record lineage. It remains local, deterministic, and source-system-simulation based; it does not add public endpoints, authentication, UI redesign, real external connectors, AI governance workflows, production data mutation, commit, or push." ;
  dcterms:created "2026-06-11"^^xsd:date ;
  dcterms:requires dcai-release:2026-06-seeded-recorded-source-scenario-generation-v1 ;
