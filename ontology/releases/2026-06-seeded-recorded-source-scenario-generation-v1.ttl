dcai-release:2026-06-seeded-recorded-source-scenario-generation-v1
  rdf:type owl:Ontology ;
  dcterms:title "Seeded recorded source-system scenario generation v1 release" ;
  dcterms:description "Internal local deterministic recorded source-system export generation for ontology-native ingestion. This release adds demo, mvp, and stress generation profiles for incident/workflow, asset/topology, work-order/validation, and telemetry/impact CSV exports; preserves stable IDs, timestamps, row ordering, quarantine examples, duplicate workflow events, and batch metadata by seed; routes generated exports through the existing recorded connector loader, SourceExtract DTOs, SHACL/provenance promotion gates, reasoning refresh, and lifecycle inspection tests. It does not add public endpoints, authentication, UI redesign, real external connectors, AI governance, commit, or push." ;
  dcterms:created "2026-06-11"^^xsd:date ;
  dcterms:requires dcai-release:2026-06-recorded-source-connector-simulation-v1 ;
