dcai-release:2026-06-phase10-semantic-service-project-scaffold
  rdf:type owl:Ontology ;
  dcterms:title "Phase 10 semantic service project scaffold release" ;
  dcterms:description "Scaffold-only release for minimal non-running Java/Kotlin semantic service build metadata, package layout placeholders, and contract wiring to Phase 8 and Phase 9 service/API contracts. This release does not implement endpoints, controllers, DTO classes, graph execution, reasoning orchestration, UI redesign, or old-runtime removal." ;
  dcterms:created "2026-06-07"^^xsd:date ;
  dcterms:requires dcai-release:2026-06-phase9-api-contract-scaffold ;
