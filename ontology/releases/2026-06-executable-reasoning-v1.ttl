dcai-release:2026-06-executable-reasoning-v1
  rdf:type owl:Ontology ;
  dcterms:title "Executable reasoning v1 release" ;
  dcterms:description "Internal executable reasoning v1 for dependency exposure, recovery blockers, restore readiness, impact trust, and blast radius over promoted canonical graphs. The service generates reasoning-audit candidate output, validates SHACL and reasoning provenance, promotes approved reasoning graph output with rollback snapshots, and records release metadata. This release does not add public endpoints, authentication, raw SPARQL exposure, AI governance workflows, frontend read-model changes, commit, or push." ;
  dcterms:created "2026-06-09"^^xsd:date ;
  dcterms:requires dcai-release:2026-06-production-ingestion-promotion-v1 ;
