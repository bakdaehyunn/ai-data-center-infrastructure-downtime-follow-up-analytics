dcai-release:2026-06-production-ingestion-promotion-v1
  rdf:type owl:Ontology ;
  dcterms:title "Production ingestion and canonical promotion v1 release" ;
  dcterms:description "Executable internal lifecycle for mapping production-style source extracts to RDF source, canonical, and provenance models; validating the combined candidate graph; promoting managed source/canonical/provenance named graphs; and rolling back target graph snapshots when a multi-graph promotion write fails. This release does not add public endpoints, authentication, reasoning refreshes, AI governance workflows, frontend read-model changes, connector jobs, commit, or push." ;
  dcterms:created "2026-06-09"^^xsd:date ;
  dcterms:requires dcai-release:2026-06-phase20-endpoint-readiness-decision ;
