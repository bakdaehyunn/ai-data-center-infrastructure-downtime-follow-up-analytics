dcai-release:2026-06-phase11-contract-loading-static-validation
  rdf:type owl:Ontology ;
  dcterms:title "Phase 11 contract loading and static validation release" ;
  dcterms:description "Implementation-slice release for Kotlin contract loading and static validation of the future semantic service contracts. This release references Phase 8, Phase 9, and Phase 10 artifacts and does not implement HTTP endpoints, graph execution, reasoning orchestration, UI redesign, or old-runtime removal." ;
  dcterms:created "2026-06-07"^^xsd:date ;
  dcterms:requires dcai-release:2026-06-phase10-semantic-service-project-scaffold ;
