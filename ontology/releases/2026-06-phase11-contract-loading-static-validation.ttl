    <../../semantic-service/src/main/kotlin/com/dcai/semanticservice/contracts/ContractArtifact.kt>,
    <../../semantic-service/src/main/kotlin/com/dcai/semanticservice/contracts/SemanticServiceContractCatalog.kt>,
    <../../semantic-service/src/main/kotlin/com/dcai/semanticservice/contracts/ContractFileLoader.kt>,
    <../../semantic-service/src/main/kotlin/com/dcai/semanticservice/contracts/StaticContractValidator.kt>,
    <../../semantic-service/src/test/kotlin/com/dcai/semanticservice/contracts/StaticContractValidatorTest.kt>,
    <../../semantic-service/build.gradle.kts>,
    <../../docs/ontology-native/phase11_contract_loading_static_validation.md> .
