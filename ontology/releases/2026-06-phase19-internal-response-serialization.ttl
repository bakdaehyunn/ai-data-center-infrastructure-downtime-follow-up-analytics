dcai-release:2026-06-phase19-internal-response-serialization
  rdf:type owl:Ontology ;
  dcterms:title "Phase 19 internal response serialization release" ;
  dcterms:description "Implementation release that adds internal-only response serialization from Phase 17 query-result envelopes and semantic errors into Phase 18-shaped in-memory payloads. This release does not implement public endpoints, graph writes, SPARQL Update execution, reasoning orchestration, UI redesign, old-runtime removal, commit, or push." ;
  dcterms:created "2026-06-07"^^xsd:date ;
  dcterms:requires dcai-release:2026-06-phase18-semantic-response-contract-checkpoint ;
  dcterms:hasPart
    <../../semantic-service/src/main/kotlin/com/dcai/semanticservice/response/SemanticResponseSerializer.kt>,
    <../../semantic-service/src/test/kotlin/com/dcai/semanticservice/response/SemanticResponseSerializerTest.kt>,
    <../../semantic-service/api-dtos.md>,
    <../../docs/ontology-native/phase19_internal_response_serialization.md> .
