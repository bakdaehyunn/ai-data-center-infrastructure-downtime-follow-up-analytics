dcai-release:2026-06-phase14-read-only-graph-access
  rdf:type owl:Ontology ;
  dcterms:title "Phase 14 read-only graph access release" ;
  dcterms:description "Implementation release that adds a read-only Jena/Fuseki graph access boundary to the Kotlin/JVM semantic service. This release does not implement public endpoints, graph writes, SPARQL Update, fixture loading, reasoning orchestration, UI redesign, old-runtime removal, commit, or push." ;
  dcterms:created "2026-06-07"^^xsd:date ;
  dcterms:requires dcai-release:2026-06-phase13-semantic-service-runnable-baseline ;
  dcterms:hasPart
    <../../semantic-service/build.gradle.kts>,
    <../../semantic-service/src/main/kotlin/com/dcai/semanticservice/graph/FusekiReadOnlyConfig.kt>,
    <../../semantic-service/src/main/kotlin/com/dcai/semanticservice/graph/ReadOnlyGraphClient.kt>,
    <../../semantic-service/src/main/kotlin/com/dcai/semanticservice/graph/JenaFusekiReadOnlyGraphClient.kt>,
    <../../semantic-service/src/main/kotlin/com/dcai/semanticservice/runtime/SemanticServiceApplication.kt>,
    <../../docs/ontology-native/phase14_read_only_graph_access.md> .
