@prefix dcai: <urn:dcai:ontology:> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcai:evidence
  rdf:type owl:Ontology ;
  dcterms:title "DCAI evidence ontology module" ;
  dcterms:description "Telemetry, validation, work-order, confidence, and trust evidence for AI data center downtime follow-up." ;
  owl:imports dcai:core ;
  owl:versionInfo "2026-06-ai-data-center-ontology-hardening-v1" .

dcai:EvidenceRecord rdf:type owl:Class ;
  rdfs:subClassOf dcai:EvidenceArtifact .
dcai:TelemetryEvidence rdf:type owl:Class ;
  rdfs:subClassOf dcai:EvidenceRecord .
dcai:ValidationEvidence rdf:type owl:Class ;
  rdfs:subClassOf dcai:EvidenceRecord .
dcai:WorkOrderEvidence rdf:type owl:Class ;
  rdfs:subClassOf dcai:EvidenceRecord .
dcai:SourceQualityIssue rdf:type owl:Class ;
  rdfs:subClassOf dcai:EvidenceArtifact .
dcai:TrustFinding rdf:type owl:Class ;
  rdfs:subClassOf dcai:DerivedFact .
dcai:EvidenceConfidenceState rdf:type owl:Class ;
  rdfs:subClassOf dcai:ControlledVocabularyTerm .
dcai:TelemetryStatus rdf:type owl:Class ;
  rdfs:subClassOf dcai:ControlledVocabularyTerm .
dcai:ValidationStatus rdf:type owl:Class ;
  rdfs:subClassOf dcai:ControlledVocabularyTerm .
dcai:WorkOrderStatus rdf:type owl:Class ;
  rdfs:subClassOf dcai:ControlledVocabularyTerm .

dcai:supportsFact rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:EvidenceRecord ;
  rdfs:range dcai:OperationalEntity .
dcai:contradictsFact rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:EvidenceRecord ;
  rdfs:range dcai:OperationalEntity .
dcai:hasConfidenceState rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:EvidenceArtifact ;
  rdfs:range xsd:string .
dcai:hasEvidenceConfidence rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:EvidenceArtifact ;
  rdfs:range dcai:EvidenceConfidenceState .
dcai:hasEvidenceSeverity rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:EvidenceArtifact ;
  rdfs:range xsd:string .
dcai:hasEvidenceTimestamp rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:EvidenceRecord ;
  rdfs:range xsd:dateTime .
dcai:hasMetricName rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:TelemetryEvidence ;
  rdfs:range xsd:string .
dcai:hasMetricValue rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:TelemetryEvidence ;
  rdfs:range xsd:decimal .
dcai:hasMetricUnit rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:TelemetryEvidence ;
  rdfs:range xsd:string .
dcai:hasTelemetryStatus rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:TelemetryEvidence ;
  rdfs:range xsd:string .
dcai:hasTelemetryState rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:TelemetryEvidence ;
  rdfs:range dcai:TelemetryStatus .
dcai:hasTelemetryAlertId rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:TelemetryEvidence ;
  rdfs:range xsd:string .
dcai:hasAlertType rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:TelemetryEvidence ;
  rdfs:range xsd:string .
dcai:hasAlertSeverity rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:TelemetryEvidence ;
  rdfs:range xsd:string .
dcai:alertTriggeredAt rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:TelemetryEvidence ;
  rdfs:range xsd:dateTime .
dcai:alertResolvedAt rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:TelemetryEvidence ;
  rdfs:range xsd:dateTime .
dcai:hasValidationId rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ValidationEvidence ;
  rdfs:range xsd:string .
dcai:hasValidationStatus rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ValidationEvidence ;
  rdfs:range xsd:string .
dcai:hasValidationState rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:ValidationEvidence ;
  rdfs:range dcai:ValidationStatus .
dcai:hasValidatorId rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ValidationEvidence ;
  rdfs:range xsd:string .
dcai:validationStartedAt rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ValidationEvidence ;
  rdfs:range xsd:dateTime .
dcai:validationCompletedAt rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ValidationEvidence ;
  rdfs:range xsd:dateTime .
dcai:hasFailureReason rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ValidationEvidence ;
  rdfs:range xsd:string .
dcai:hasWorkOrderId rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkOrderEvidence ;
  rdfs:range xsd:string .
dcai:hasAssignedTeam rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkOrderEvidence ;
  rdfs:range xsd:string .
dcai:hasAssignedEngineerId rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkOrderEvidence ;
  rdfs:range xsd:string .
dcai:hasWorkOrderStatus rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkOrderEvidence ;
  rdfs:range xsd:string .
dcai:hasWorkOrderState rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:WorkOrderEvidence ;
  rdfs:range dcai:WorkOrderStatus .
dcai:plannedStartAt rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkOrderEvidence ;
  rdfs:range xsd:dateTime .
dcai:actualStartAt rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkOrderEvidence ;
  rdfs:range xsd:dateTime .
dcai:actualCompletedAt rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkOrderEvidence ;
  rdfs:range xsd:dateTime .
dcai:hasRequiredSpareId rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkOrderEvidence ;
  rdfs:range xsd:string .
dcai:hasRequiredSpareName rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkOrderEvidence ;
  rdfs:range xsd:string .
dcai:hasStockStatus rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkOrderEvidence ;
  rdfs:range xsd:string .
