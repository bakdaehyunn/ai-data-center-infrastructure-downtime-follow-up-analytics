@prefix dcai: <urn:dcai:ontology:> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcai:infrastructure
  rdf:type owl:Ontology ;
  dcterms:title "DCAI infrastructure ontology module" ;
  dcterms:description "Phase 2 skeleton for facilities, zones, assets, and compute capacity groups." ;
  owl:imports dcai:core ;
  owl:versionInfo "2026-06-phase2-skeleton" .

dcai:Facility rdf:type owl:Class ;
  rdfs:subClassOf dcai:InfrastructureEntity .
dcai:InfrastructureZone rdf:type owl:Class ;
  rdfs:subClassOf dcai:InfrastructureEntity .
dcai:InfrastructureAsset rdf:type owl:Class ;
  rdfs:subClassOf dcai:InfrastructureEntity .
dcai:PowerAsset rdf:type owl:Class ;
  rdfs:subClassOf dcai:InfrastructureAsset .
dcai:CoolingAsset rdf:type owl:Class ;
  rdfs:subClassOf dcai:InfrastructureAsset .
dcai:ControlTelemetryAsset rdf:type owl:Class ;
  rdfs:subClassOf dcai:InfrastructureAsset .
dcai:ComputeCapacityGroup rdf:type owl:Class ;
  rdfs:subClassOf dcai:InfrastructureEntity .

dcai:locatedIn rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:InfrastructureAsset ;
  rdfs:range dcai:InfrastructureZone .
dcai:zoneInFacility rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:InfrastructureZone ;
  rdfs:range dcai:Facility .
dcai:hasAssetType rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:InfrastructureAsset ;
  rdfs:range xsd:string .
dcai:hasCriticalityLevel rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:InfrastructureAsset ;
  rdfs:range xsd:string .
dcai:hasOperationalStatus rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:InfrastructureEntity ;
  rdfs:range xsd:string .
