@prefix dcai: <urn:dcai:ontology:> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcai:ai-interaction
  rdf:type owl:Ontology ;
  dcterms:title "DCAI AI interaction ontology module" ;
  dcterms:description "Phase 2 skeleton for governed AI graph questions, generated SPARQL, proposed triples, approvals, and guardrail violations." ;
  owl:imports dcai:core, dcai:provenance ;
  owl:versionInfo "2026-06-phase2-skeleton" .

dcai:AIInteraction rdf:type owl:Class ;
  rdfs:subClassOf dcai:OperationalEvent .
dcai:AIQuestion rdf:type owl:Class ;
  rdfs:subClassOf dcai:AIInteraction .
dcai:GeneratedSparql rdf:type owl:Class ;
  rdfs:subClassOf dcai:EvidenceArtifact .
dcai:ProposedTripleSet rdf:type owl:Class ;
  rdfs:subClassOf dcai:EvidenceArtifact .
dcai:AIApprovalDecision rdf:type owl:Class ;
  rdfs:subClassOf dcai:OperationalEvent .
dcai:AIGuardrailViolation rdf:type owl:Class ;
  rdfs:subClassOf dcai:EvidenceArtifact .

dcai:generatedQuery rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:GeneratedSparql ;
  rdfs:range xsd:string .
dcai:proposesTriple rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ProposedTripleSet ;
  rdfs:range xsd:string .
dcai:hasApprovalState rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:AIApprovalDecision ;
  rdfs:range xsd:string .
dcai:blockedByGuardrail rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:AIInteraction ;
  rdfs:range dcai:AIGuardrailViolation .
dcai:validatedAgainstShape rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ProposedTripleSet ;
  rdfs:range xsd:anyURI .
