@prefix dcai: <urn:dcai:ontology:> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcai:topology
  rdf:type owl:Ontology ;
  dcterms:title "DCAI topology ontology module" ;
  dcterms:description "Phase 2 skeleton for dependency edges and infrastructure paths." ;
  owl:imports dcai:core, dcai:infrastructure ;
  owl:versionInfo "2026-06-phase2-skeleton" .

dcai:DependencyEdge rdf:type owl:Class ;
  rdfs:subClassOf dcai:OperationalEntity .
dcai:DependencyPath rdf:type owl:Class ;
  rdfs:subClassOf dcai:OperationalEntity .
dcai:PowerPath rdf:type owl:Class ;
  rdfs:subClassOf dcai:DependencyPath .
dcai:CoolingPath rdf:type owl:Class ;
  rdfs:subClassOf dcai:DependencyPath .
dcai:TelemetryPath rdf:type owl:Class ;
  rdfs:subClassOf dcai:DependencyPath .
dcai:RedundancyPath rdf:type owl:Class ;
  rdfs:subClassOf dcai:DependencyPath .

dcai:dependsOn rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:InfrastructureAsset ;
  rdfs:range dcai:InfrastructureAsset .
dcai:supports rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:InfrastructureAsset ;
  rdfs:range dcai:InfrastructureAsset .
dcai:hasDependentAsset rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:DependencyEdge ;
  rdfs:range dcai:InfrastructureAsset .
dcai:hasDependencyAsset rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:DependencyEdge ;
  rdfs:range dcai:InfrastructureAsset .
dcai:hasDependencyRole rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:DependencyEdge ;
  rdfs:range xsd:string .
dcai:hasImpactScope rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:DependencyEdge ;
  rdfs:range xsd:string .
dcai:hasPathStep rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:DependencyPath ;
  rdfs:range dcai:DependencyEdge .
