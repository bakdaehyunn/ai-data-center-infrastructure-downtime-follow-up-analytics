@prefix dcai: <urn:dcai:ontology:> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcai:workflow
  rdf:type owl:Ontology ;
  dcterms:title "DCAI workflow ontology module" ;
  dcterms:description "Incident stages, workflow events, recovery blockers, and follow-up decisions for AI data center downtime operations." ;
  owl:imports dcai:core, dcai:infrastructure ;
  owl:versionInfo "2026-06-ai-data-center-ontology-hardening-v1" .

dcai:InfrastructureIncident rdf:type owl:Class ;
  rdfs:subClassOf dcai:OperationalEntity .
dcai:WorkflowStage rdf:type owl:Class .
dcai:WorkflowEvent rdf:type owl:Class ;
  rdfs:subClassOf dcai:OperationalEvent .
dcai:RecoveryBlocker rdf:type owl:Class ;
  rdfs:subClassOf dcai:DerivedFact .
dcai:FollowUpDecision rdf:type owl:Class ;
  rdfs:subClassOf dcai:DerivedFact .
dcai:IncidentStageState rdf:type owl:Class ;
  rdfs:subClassOf dcai:ControlledVocabularyTerm .
dcai:WorkflowEventStatus rdf:type owl:Class ;
  rdfs:subClassOf dcai:ControlledVocabularyTerm .

dcai:affectsAsset rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:InfrastructureIncident ;
  rdfs:range dcai:InfrastructureAsset .
dcai:hasCurrentStage rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:InfrastructureIncident ;
  rdfs:range dcai:WorkflowStage .
dcai:hasIncidentStageState rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:InfrastructureIncident ;
  rdfs:range dcai:IncidentStageState .
dcai:enteredStage rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:WorkflowEvent ;
  rdfs:range dcai:WorkflowStage .
dcai:exitedStage rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:WorkflowEvent ;
  rdfs:range dcai:WorkflowStage .
dcai:hasAllowedNextStage rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:WorkflowStage ;
  rdfs:range dcai:WorkflowStage .
dcai:eventForIncident rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:WorkflowEvent ;
  rdfs:range dcai:InfrastructureIncident .
dcai:hasEventId rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkflowEvent ;
  rdfs:range xsd:string .
dcai:hasEventStatus rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkflowEvent ;
  rdfs:range xsd:string .
dcai:hasWorkflowEventStatus rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:WorkflowEvent ;
  rdfs:range dcai:WorkflowEventStatus .
dcai:enteredAt rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkflowEvent ;
  rdfs:range xsd:dateTime .
dcai:exitedAt rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkflowEvent ;
  rdfs:range xsd:dateTime .
dcai:hasDurationHours rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkflowEvent ;
  rdfs:range xsd:decimal .
dcai:hasDelayHours rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkflowEvent ;
  rdfs:range xsd:decimal .
dcai:hasStageThresholdHours rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:WorkflowStage ;
  rdfs:range xsd:decimal .
dcai:hasRecommendedAction rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:FollowUpDecision ;
  rdfs:range xsd:string .
