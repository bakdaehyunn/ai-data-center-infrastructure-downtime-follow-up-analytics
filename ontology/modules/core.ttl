@prefix dcai: <urn:dcai:ontology:> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcai:core
  rdf:type owl:Ontology ;
  dcterms:title "DCAI core ontology module" ;
  dcterms:description "Phase 2 skeleton for shared identifiers, timestamps, source systems, and cross-module superclasses." ;
  owl:versionInfo "2026-06-phase2-skeleton" .

dcai:OperationalEntity rdf:type owl:Class .
dcai:InfrastructureEntity rdf:type owl:Class ;
  rdfs:subClassOf dcai:OperationalEntity .
dcai:OperationalEvent rdf:type owl:Class ;
  rdfs:subClassOf dcai:OperationalEntity .
dcai:EvidenceArtifact rdf:type owl:Class ;
  rdfs:subClassOf dcai:OperationalEntity .
dcai:DerivedFact rdf:type owl:Class ;
  rdfs:subClassOf dcai:OperationalEntity .
dcai:SourceSystem rdf:type owl:Class .

dcai:hasIdentifier rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:OperationalEntity ;
  rdfs:range xsd:string .
dcai:hasSourceSystem rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:OperationalEntity ;
  rdfs:range dcai:SourceSystem .
dcai:observedAt rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:OperationalEntity ;
  rdfs:range xsd:dateTime .
dcai:createdAt rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:OperationalEntity ;
  rdfs:range xsd:dateTime .
