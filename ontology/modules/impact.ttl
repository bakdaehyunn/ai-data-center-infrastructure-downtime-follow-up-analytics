@prefix dcai: <urn:dcai:ontology:> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

dcai:impact
  rdf:type owl:Ontology ;
  dcterms:title "DCAI impact ontology module" ;
  dcterms:description "Phase 2 skeleton for operational exposure observations." ;
  owl:imports dcai:core, dcai:workflow, dcai:infrastructure ;
  owl:versionInfo "2026-06-phase2-skeleton" .

dcai:ImpactObservation rdf:type owl:Class ;
  rdfs:subClassOf dcai:EvidenceArtifact .
dcai:CapacityExposure rdf:type owl:Class ;
  rdfs:subClassOf dcai:ImpactObservation .
dcai:GpuExposure rdf:type owl:Class ;
  rdfs:subClassOf dcai:ImpactObservation .
dcai:ThermalExposure rdf:type owl:Class ;
  rdfs:subClassOf dcai:ImpactObservation .
dcai:RedundancyExposure rdf:type owl:Class ;
  rdfs:subClassOf dcai:ImpactObservation .
dcai:VendorExposure rdf:type owl:Class ;
  rdfs:subClassOf dcai:ImpactObservation .

dcai:impactForIncident rdf:type owl:ObjectProperty ;
  rdfs:domain dcai:ImpactObservation ;
  rdfs:range dcai:InfrastructureIncident .
dcai:estimatedCapacityRiskKw rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ImpactObservation ;
  rdfs:range xsd:decimal .
dcai:affectedGpuCount rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ImpactObservation ;
  rdfs:range xsd:integer .
dcai:affectedRackCount rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ImpactObservation ;
  rdfs:range xsd:integer .
dcai:estimatedGpuCapacityRiskPct rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ImpactObservation ;
  rdfs:range xsd:decimal .
dcai:thermalBreachMinutes rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ImpactObservation ;
  rdfs:range xsd:integer .
dcai:powerRedundancyLost rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ImpactObservation ;
  rdfs:range xsd:boolean .
dcai:coolingRedundancyLost rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ImpactObservation ;
  rdfs:range xsd:boolean .
dcai:hasRedundancyState rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ImpactObservation ;
  rdfs:range xsd:string .
dcai:hasMitigationState rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ImpactObservation ;
  rdfs:range xsd:string .
dcai:hasVendorState rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ImpactObservation ;
  rdfs:range xsd:string .
dcai:vendorEtaAt rdf:type owl:DatatypeProperty ;
  rdfs:domain dcai:ImpactObservation ;
  rdfs:range xsd:dateTime .
