PREFIX dcai: <urn:dcai:ontology:>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT
  ?graph
  ?incident
  ?incidentId
  ?stage
  ?stageLabel
  ?sourceRecord
  ?impact
  ?evidence
  ?evidenceClass
  ?evidenceTimestamp
  ?confidenceState
  ?metricName
  ?metricValue
  ?metricUnit
  ?telemetryStatus
  ?telemetryAlertId
  ?alertType
  ?alertSeverity
  ?alertTriggeredAt
  ?alertResolvedAt
  ?validationId
  ?validationStatus
  ?validatorId
  ?validationStartedAt
  ?validationCompletedAt
  ?failureReason
  ?workOrderId
  ?assignedTeam
  ?assignedEngineerId
  ?workOrderStatus
  ?plannedStartAt
  ?actualStartAt
  ?actualCompletedAt
  ?requiredSpareId
  ?requiredSpareName
  ?stockStatus
  ?trustFinding
  ?trustSummary
WHERE {
  GRAPH ?graph {
    ?incident a dcai:InfrastructureIncident ;
      dcai:hasIdentifier ?incidentId ;
      dcai:hasCurrentStage ?stage ;
      prov:wasDerivedFrom ?sourceRecord .
    OPTIONAL { ?stage rdfs:label ?stageLabel . }
    OPTIONAL {
      ?impact a dcai:ImpactObservation ;
        dcai:impactForIncident ?incident .
    }
    OPTIONAL {
      ?evidence rdf:type/rdfs:subClassOf* dcai:EvidenceRecord ;
        dcai:supportsFact ?supportedFact .
      FILTER(?supportedFact = ?incident || (BOUND(?impact) && ?supportedFact = ?impact))
      OPTIONAL {
        ?evidence a ?evidenceClass .
        FILTER(?evidenceClass IN (dcai:TelemetryEvidence, dcai:ValidationEvidence, dcai:WorkOrderEvidence, dcai:EvidenceRecord))
      }
      OPTIONAL { ?evidence dcai:hasEvidenceTimestamp ?evidenceTimestamp . }
      OPTIONAL { ?evidence dcai:hasConfidenceState ?confidenceState . }
      OPTIONAL { ?evidence dcai:hasMetricName ?metricName . }
      OPTIONAL { ?evidence dcai:hasMetricValue ?metricValue . }
      OPTIONAL { ?evidence dcai:hasMetricUnit ?metricUnit . }
      OPTIONAL { ?evidence dcai:hasTelemetryStatus ?telemetryStatus . }
      OPTIONAL { ?evidence dcai:hasTelemetryAlertId ?telemetryAlertId . }
      OPTIONAL { ?evidence dcai:hasAlertType ?alertType . }
      OPTIONAL { ?evidence dcai:hasAlertSeverity ?alertSeverity . }
      OPTIONAL { ?evidence dcai:alertTriggeredAt ?alertTriggeredAt . }
      OPTIONAL { ?evidence dcai:alertResolvedAt ?alertResolvedAt . }
      OPTIONAL { ?evidence dcai:hasValidationId ?validationId . }
      OPTIONAL { ?evidence dcai:hasValidationStatus ?validationStatus . }
      OPTIONAL { ?evidence dcai:hasValidatorId ?validatorId . }
      OPTIONAL { ?evidence dcai:validationStartedAt ?validationStartedAt . }
      OPTIONAL { ?evidence dcai:validationCompletedAt ?validationCompletedAt . }
      OPTIONAL { ?evidence dcai:hasFailureReason ?failureReason . }
      OPTIONAL { ?evidence dcai:hasWorkOrderId ?workOrderId . }
      OPTIONAL { ?evidence dcai:hasAssignedTeam ?assignedTeam . }
      OPTIONAL { ?evidence dcai:hasAssignedEngineerId ?assignedEngineerId . }
      OPTIONAL { ?evidence dcai:hasWorkOrderStatus ?workOrderStatus . }
      OPTIONAL { ?evidence dcai:plannedStartAt ?plannedStartAt . }
      OPTIONAL { ?evidence dcai:actualStartAt ?actualStartAt . }
      OPTIONAL { ?evidence dcai:actualCompletedAt ?actualCompletedAt . }
      OPTIONAL { ?evidence dcai:hasRequiredSpareId ?requiredSpareId . }
      OPTIONAL { ?evidence dcai:hasRequiredSpareName ?requiredSpareName . }
      OPTIONAL { ?evidence dcai:hasStockStatus ?stockStatus . }
    }
  }
  OPTIONAL {
    GRAPH ?reasoningGraph {
      ?trustFinding a dcai:TrustFinding ;
        prov:wasDerivedFrom ?trustSource ;
        dcai:hasFindingSummary ?trustSummary .
    }
    FILTER(STRSTARTS(STR(?reasoningGraph), "urn:dcai:graph:fixture:canonical:") || STRSTARTS(STR(?reasoningGraph), "urn:dcai:graph:reasoning:"))
    FILTER(?trustSource = ?incident || (BOUND(?impact) && ?trustSource = ?impact) || (BOUND(?evidence) && ?trustSource = ?evidence))
  }
  FILTER(STRSTARTS(STR(?graph), "urn:dcai:graph:fixture:canonical:") || STRSTARTS(STR(?graph), "urn:dcai:graph:canonical:"))
  FILTER(?incidentId = COALESCE(?incidentIdParam, ?incidentId))
}
ORDER BY ?incidentId ?evidence ?trustFinding
