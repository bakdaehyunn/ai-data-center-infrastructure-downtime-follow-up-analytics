PREFIX dcai: <urn:dcai:ontology:>
PREFIX prov: <http://www.w3.org/ns/prov#>

SELECT ?graph ?trustFinding ?summary ?sourceFact ?activity
WHERE {
  GRAPH ?graph {
    ?trustFinding a dcai:TrustFinding ;
      dcai:hasFindingSummary ?summary ;
      prov:wasDerivedFrom ?sourceFact .
    OPTIONAL { ?trustFinding prov:wasGeneratedBy ?activity . }
  }
  FILTER(STRSTARTS(STR(?graph), "urn:dcai:graph:fixture:canonical:"))
}
ORDER BY ?trustFinding
