  rdf:type dcai-query:QueryEntry ;
  dcterms:title "Future valid fixture conformance query" ;
  dcai-query:queryPath "queries/validation/valid_fixture_conformance.ask.rq" ;
  dcai-query:queryMode "ASK" ;
  dcai-query:graphScope "fixture graph, shapes graph" ;
  dcai-query:implementationStatus "placeholder" .

